{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ielts",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-28",
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "APP_TITLE": "IELTS Reading Lab"
  }
}
