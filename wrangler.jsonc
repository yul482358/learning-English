{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ielts",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-28",
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ielts-reading-lab",
      "database_id": "REPLACE_WITH_CLOUDFLARE_D1_DATABASE_ID"
    }
  ],
  "vars": {
    "APP_TITLE": "IELTS Reading Lab"
  }
}
